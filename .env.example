# AegisLegacy backend configuration (copy to .env for local dev)

# API
AEGIS_API_HOST=0.0.0.0
AEGIS_API_PORT=8000
AEGIS_API_KEY=changeme-local-dev-key

# Database (SQLite by default for the "core" edition; swap for Postgres in production)
AEGIS_DATABASE_URL=sqlite:///./aegislegacy.db

# Rules
AEGIS_RULES_DIR=../rules

# Reports
AEGIS_REPORTS_DIR=./reports

# Logging
AEGIS_LOG_LEVEL=INFO
AEGIS_LOG_FORMAT=json
